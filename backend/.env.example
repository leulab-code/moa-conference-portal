# ─────────────────────────────────────────────────────────────
# Conference Management System — Backend Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your actual values.
# NEVER commit the real .env to version control.

# Django
SECRET_KEY=django-insecure-change-me-to-a-strong-random-key
DEBUG=True
ALLOWED_HOSTS=*

# PostgreSQL
DB_NAME=conference_db
DB_USER=postgres
DB_PASSWORD=Leul@0987
DB_HOST=localhost
DB_PORT=5432

# CORS
CORS_ALLOW_ALL_ORIGINS=True
# In production, set CORS_ALLOW_ALL_ORIGINS=False and list your frontend URL:
# CORS_ALLOWED_ORIGINS=https://your-frontend.example.com
